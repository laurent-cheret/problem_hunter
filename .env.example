# ─────────────────────────────────────────────────────────────
# Problem Hunter — environment variables
# Copy this to .env for local development.
# In Railway, set these via the Variables tab in your project.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (get bot token from @BotFather, chat ID from @userinfobot)
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# X / Twitter (used only for first login, then replaced by TWITTER_COOKIES_JSON)
# After running setup_twitter.py locally, you can leave these blank in Railway.
TWITTER_USERNAME=your_x_username
TWITTER_EMAIL=your@email.com
TWITTER_PASSWORD=your_password

# Twitter session cookies (generated by setup_twitter.py — paste the JSON string here)
TWITTER_COOKIES_JSON=

# Database (Railway injects this automatically when you add the Postgres plugin)
# For local dev, set this manually.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/problemhunter
